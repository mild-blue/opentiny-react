{
  "description": "Official OpenTiny React Component",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mild-blue/opentiny-react.git"
  },
  "files": [
    "lib",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.txt"
  ],
  "main": "lib/cjs/main/ts/index.js",
  "module": "lib/es2015/main/ts/index.js",
  "types": "lib/cjs/main/ts/index.d.ts",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "lint": "eslint 'src/**/*.ts?(x)'",
    "clean": "rimraf lib",
    "test": "bedrock-auto -b chrome-headless -f src/test/ts/**/*Test.ts",
    "test-manual": "bedrock -f src/test/ts/**/*Test.ts",
    "build": "yarn run clean && tsc -p ./tsconfig.es2015.json && tsc -p ./tsconfig.cjs.json",
    "watch": "tsc -w -p ./tsconfig.es2015.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy-storybook": "storybook build && gh-pages -d ./storybook-static -u 'tiny-bot <no-reply@tiny.cloud>' --nojekyll"
  },
  "keywords": [],
  "author": "Ephox Corporation DBA Tiny Technologies, Inc.",
  "license": "MIT",
  "dependencies": {
    "prop-types": "^15.6.2"
  },
  "resolutions": {
    "fast-xml-parser": "^4.5.4",
    "lodash": "^4.18.1",
    "basic-ftp": "^5.3.0",
    "micromatch": "^4.0.8",
    "@babel/runtime": "^7.26.10",
    "yaml": "^1.10.3",
    "diff": "^5.2.2",
    "cross-spawn": "^7.0.6",
    "ws": "^8.18.0",
    "tar-fs": "^3.1.3",
    "serve-static": "^1.16.3",
    "send": "^0.19.2",
    "uuid": "^11.1.1",
    "ip-address": "^10.1.1"
  },
  "peerDependencies": {
    "opentiny": "^6.9.0",
    "react": "^19.0.0 || ^18.0.0 || ^17.0.1 || ^16.7.0",
    "react-dom": "^19.0.0 || ^18.0.0 || ^17.0.1 || ^16.7.0"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@ephox/agar": "^8.0.0-alpha.0",
    "@ephox/bedrock-client": "^16.0.0",
    "@ephox/bedrock-server": "^16.2.0",
    "@ephox/katamari": "^9.1.5",
    "@ephox/mcagar": "^9.0.0-alpha.0",
    "@ephox/sand": "^6.0.9",
    "@ephox/sugar": "^9.2.1",
    "@storybook/addon-docs": "^10.4.6",
