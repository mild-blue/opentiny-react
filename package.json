    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tinymce/eslint-plugin": "^2.3.1",
    "@types/node": "^20.9.0",
    "@types/prop-types": "^15.7.10",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "gh-pages": "^6.1.0",
    "opentiny": "^6.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^6.0.1",
    "storybook": "^10.4.6",
    "typescript": "~5.4.3",
    "vite": "^6.4.2"
  },
  "version": "0.0.0",
  "name": "opentiny-react"
